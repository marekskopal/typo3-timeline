{
    "name": "marekskopal/typo3-timeline",
    "type": "typo3-cms-extension",
    "description": "Timeline events plugin for TYPO3 CMS",
    "keywords": [
        "TYPO3",
        "timeline",
        "events"
    ],
    "homepage": "https://marekskopal.cz",
    "authors": [
        {
            "name": "Marek Skopal",
            "role": "Developer",
            "homepage": "https://marekskopal.cz"
        }
    ],
    "license": ["GPL-2.0-or-later"],
    "require": {
        "php": ">=8.3",
        "typo3/cms-core": "^13.4.24 || ^14.1.0",
        "typo3/cms-extbase": "^13.4.24 || ^14.1.0"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.0",
        "shipmonk/phpstan-rules": "^4.0",
        "slevomat/coding-standard": "^8.14"
    },
    "autoload": {
        "psr-4": {
            "MarekSkopal\\MsTimeline\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "ms_timeline"
        }
    },
    "config": {
        "platform": {
            "php": "8.3"
        },
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    }
}
